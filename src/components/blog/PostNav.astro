---
import { type Lang } from "../../i18n/translations";

export interface PostNavLink {
  title: string;
  href: string;
}

interface Props {
  prev?: PostNavLink;
  next?: PostNavLink;
  lang?: Lang;
}

const { prev, next, lang = "en" } = Astro.props;
const prevLabel = lang === "tr" ? "Önceki" : "Previous";
const nextLabel = lang === "tr" ? "Sonraki" : "Next";
---

{
  (prev || next) && (
    <nav class="post-nav" aria-label={lang === "tr" ? "Yazı gezinme" : "Post navigation"}>
      {prev ? (
        <a class="post-nav-link prev" href={prev.href}>
          <span class="post-nav-label">← {prevLabel}</span>
          <span class="post-nav-title">{prev.title}</span>
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a class="post-nav-link next" href={next.href}>
          <span class="post-nav-label">{nextLabel} →</span>
          <span class="post-nav-title">{next.title}</span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}

<style>
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--blog-content-width, 640px);
    margin: 2rem auto 0;
    font-family: "Inter", system-ui, sans-serif;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 46%;
    text-decoration: none;
  }

  .post-nav-link.next {
    text-align: right;
    margin-left: auto;
  }

  .post-nav-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-nav-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .post-nav {
      flex-direction: column;
    }

    .post-nav-link,
    .post-nav-link.next {
      max-width: 100%;
    }
  }
</style>
