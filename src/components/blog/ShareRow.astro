---
import { Link2, Twitter, Linkedin } from "@lucide/astro";
import { type Lang } from "../../i18n/translations";

interface Props {
  title: string;
  lang?: Lang;
}

const { title, lang = "en" } = Astro.props;
const url = Astro.url.href;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const copyLabel = lang === "tr" ? "Bağlantıyı kopyala" : "Copy link";
const copiedLabel = lang === "tr" ? "Kopyalandı" : "Copied";
const shareLabel = lang === "tr" ? "Paylaş" : "Share";
---

<div class="share-row">
  <span class="share-label">{shareLabel}</span>
  <button
    class="share-btn"
    data-copy-link
    data-copied-label={copiedLabel}
    aria-label={copyLabel}
    title={copyLabel}
  >
    <Link2 size={15} />
    <span data-copy-text>{copyLabel}</span>
  </button>
  <a
    class="share-btn"
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noreferrer"
    aria-label="Share on X"
  >
    <Twitter size={15} />
    X
  </a>
  <a
    class="share-btn"
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    target="_blank"
    rel="noreferrer"
    aria-label="Share on LinkedIn"
  >
    <Linkedin size={15} />
    LinkedIn
  </a>
</div>

<script>
  function initShareRow() {
    document
      .querySelectorAll<HTMLButtonElement>("[data-copy-link]:not([data-init])")
      .forEach((btn) => {
        btn.dataset.init = "true";
        btn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            const text = btn.querySelector("[data-copy-text]");
            if (text) {
              const original = text.textContent;
              text.textContent = btn.dataset.copiedLabel || "Copied";
              setTimeout(() => {
                text.textContent = original;
              }, 1800);
            }
          } catch {
            /* clipboard unavailable */
          }
        });
      });
  }

  initShareRow();
  document.addEventListener("astro:after-swap", initShareRow);
</script>

<style>
  .share-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    max-width: var(--blog-content-width, 640px);
    margin: 0 auto;
  }

  .share-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-right: 0.25rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    font-family: "Inter", system-ui, sans-serif;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 9999px;
    text-decoration: none;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .share-btn:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
  }
</style>
