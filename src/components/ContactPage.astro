---
import {
  Github,
  Linkedin,
  Instagram,
  Twitter,
  Mail,
  Music,
} from "@lucide/astro";
import { type Lang } from "../i18n/translations";
import { SITE_CONFIG } from "../consts";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = lang === "tr";

const copy = {
  title: tr ? "İletişim" : "Contact",
  intro: tr
    ? "Bir sorunuz mu var? Ulaşmaktan çekinmeyin. En hızlı cevap e-postadan gelir."
    : "Have a question? Reach out. Email gets the fastest reply.",
};

const channels = [
  {
    name: "GitHub",
    href: SITE_CONFIG.social.github,
    desc: tr
      ? "Yaptıklarımın çoğu, çeşitli bitmişlik seviyelerinde burada."
      : "Most of what I build ends up here, in various states of finished.",
    meta: "@busahinku",
    accent: "#8b5cf6",
    span: "wide",
    icon: "github",
  },
  {
    name: "LinkedIn",
    href: SITE_CONFIG.social.linkedin,
    desc: tr
      ? "Merhaba deyin. Yeni insanlarla tanışmayı gerçekten severim."
      : "Say hi. I genuinely like meeting new people.",
    meta: "in/sahinkucuk",
    accent: "#3b82f6",
    span: "wide",
    icon: "linkedin",
  },
  {
    name: "Spotify",
    href: SITE_CONFIG.social.spotify,
    desc: tr
      ? "Çalışırken müzik benim varsayılan halim. Çalma listelerimi yargılayabilirsiniz."
      : "Music is my default state while working. Judge my playlists freely.",
    meta: tr ? "çalma listeleri" : "playlists",
    accent: "#22c55e",
    span: "narrow",
    icon: "music",
  },
  {
    name: "X",
    href: SITE_CONFIG.social.twitter,
    desc: tr ? "Ara sıra kısa düşünceler." : "Short thoughts, occasionally.",
    meta: "@busahinku",
    accent: "#64748b",
    span: "narrow",
    icon: "twitter",
  },
  {
    name: "Instagram",
    href: SITE_CONFIG.social.instagram,
    desc: tr
      ? "Çoğunlukla takipteyim. Nadiren bir fotoğraf düşer."
      : "Mostly lurking. A photo appears once in a blue moon.",
    meta: "@busahinku",
    accent: "#ec4899",
    span: "narrow",
    icon: "instagram",
  },
  {
    name: tr ? "E-posta" : "Email",
    href: `mailto:${SITE_CONFIG.email}`,
    desc: tr
      ? "Bana ulaşmanın en hızlı yolu. Hepsini okuyorum."
      : "The fastest way to reach me. I read everything.",
    meta: SITE_CONFIG.email,
    accent: "#22d3ee",
    span: "full",
    icon: "mail",
  },
];
---

<div class="contact-page">
  <header class="page-head">
    <h1>{copy.title}</h1>
    <p class="page-intro">{copy.intro}</p>
  </header>

  <div class="channel-grid">
    {
      channels.map((channel) => (
        <a
          class:list={["channel-card", `span-${channel.span}`]}
          href={channel.href}
          target={channel.href.startsWith("mailto") ? undefined : "_blank"}
          rel="noreferrer"
          style={`--card-accent: ${channel.accent};`}
        >
          <span class="card-top">
            <span class="card-name">
              <span class="card-icon" aria-hidden="true">
                {channel.icon === "github" && <Github size={17} />}
                {channel.icon === "linkedin" && <Linkedin size={17} />}
                {channel.icon === "music" && <Music size={17} />}
                {channel.icon === "twitter" && <Twitter size={17} />}
                {channel.icon === "instagram" && <Instagram size={17} />}
                {channel.icon === "mail" && <Mail size={17} />}
              </span>
              {channel.name}
            </span>
            <span class="card-meta">{channel.meta}</span>
          </span>
          <span class="card-desc">{channel.desc}</span>
        </a>
      ))
    }
  </div>
</div>

<style>
  .contact-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 1rem 0 2rem;
  }

  .page-head {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .page-head h1 {
    font-family: "Melodrama", serif;
    font-weight: 600;
    font-size: clamp(2rem, 5.5vw, 2.75rem);
    line-height: 1.1;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
  }

  .page-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Bento grid */
  .channel-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
  }

  .span-wide {
    grid-column: span 3;
  }

  .span-narrow {
    grid-column: span 2;
  }

  .span-full {
    grid-column: span 6;
  }

  .channel-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.125rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: linear-gradient(
      135deg,
      var(--bg-secondary) 0%,
      color-mix(in srgb, var(--card-accent) 6%, var(--bg-secondary)) 100%
    );
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .channel-card:hover {
    border-color: color-mix(in srgb, var(--card-accent) 45%, var(--border));
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -12px var(--shadow);
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-name {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .card-icon {
    display: inline-flex;
    color: color-mix(in srgb, var(--card-accent) 80%, var(--text-muted));
    transform: translateY(2px);
  }

  .card-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .channel-grid {
      grid-template-columns: 1fr 1fr;
    }

    .span-wide,
    .span-full {
      grid-column: span 2;
    }

    .span-narrow {
      grid-column: span 2;
    }
  }
</style>
