---
import { type Lang } from "../i18n/translations";
import { SITE_CONFIG } from "../consts";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = lang === "tr";
const basePath = tr ? "/tr" : "";

const copy = {
  title: tr ? "Ivır zıvır" : "Miscellany",
  intro: tr
    ? "Bu sitenin karışık çekmecesi: müzik, bağlantılar, kitaplar ve gerçekten kullandığım araçlar."
    : "The overflow drawer of this site: music, links, books, and the tools I actually use.",
  listening: tr ? "Dinlediklerim" : "Listening",
  listeningDesc: tr
    ? "Müzik, yaptığım hemen her şeyin fonunda çalar. Şu sıralar dönenler:"
    : "Music runs under almost everything I do. This is what's on lately:",
  spotifyFollow: tr ? "Spotify'da takip et" : "Follow along on Spotify",
  bookmarks: tr ? "Yer imleri" : "Bookmarks",
  bookmarksDesc: tr
    ? "Dönüp dolaşıp yine açtığım bağlantılar."
    : "Links I keep coming back to.",
  allBookmarks: tr ? "Tüm yer imleri" : "All bookmarks",
  books: tr ? "Kitaplar" : "Books",
  booksDesc: tr
    ? "Düşünme ya da çalışma şeklimi değiştiren kitaplar."
    : "Books that changed how I think or work.",
  allBooks: tr ? "Tüm kitaplar" : "All books",
  sources: tr ? "Kaynaklar" : "Sources",
  sourcesDesc: tr
    ? "Günlük haber ve fikir dozumu aldığım yerler."
    : "Where the daily dose of news and ideas comes from.",
  allSources: tr ? "Tüm kaynaklar" : "All sources",
  desk: tr ? "Masamda" : "The desk",
  deskDesc: tr
    ? "Günlük kullanıma dayanabilen donanım ve yazılımlar."
    : "The hardware and software that survive daily use.",
};

const sectionIndex = [
  { id: "listening", label: copy.listening },
  { id: "bookmarks", label: copy.bookmarks },
  { id: "books", label: copy.books },
  { id: "sources", label: copy.sources },
  { id: "desk", label: copy.desk },
];

const bookmarks = [
  {
    title: "Refactoring UI",
    url: "https://www.refactoringui.com/",
    category: tr ? "Tasarım" : "Design",
  },
  {
    title: "Realtime Colors",
    url: "https://www.realtimecolors.com/",
    category: tr ? "Tasarım" : "Design",
  },
  {
    title: "Josh W Comeau",
    url: "https://www.joshwcomeau.com/",
    category: "Blog",
  },
  { title: "Syntax.fm", url: "https://syntax.fm/", category: "Podcast" },
  {
    title: "Frontend Masters",
    url: "https://frontendmasters.com/",
    category: tr ? "Öğrenme" : "Learning",
  },
];

const books = [
  {
    title: "Clean Code",
    author: "Robert C. Martin",
    category: tr ? "Programlama" : "Programming",
  },
  {
    title: "The Pragmatic Programmer",
    author: "David Thomas",
    category: tr ? "Programlama" : "Programming",
  },
  {
    title: "Designing Data-Intensive Applications",
    author: "Martin Kleppmann",
    category: tr ? "Sistemler" : "Systems",
  },
  {
    title: "Atomic Habits",
    author: "James Clear",
    category: tr ? "Kişisel Gelişim" : "Self-Help",
  },
  {
    title: "Deep Work",
    author: "Cal Newport",
    category: tr ? "Verimlilik" : "Productivity",
  },
];

const sources = [
  {
    title: "Hacker News",
    url: "https://news.ycombinator.com/",
    category: tr ? "Haberler" : "News",
  },
  {
    title: "Dev.to",
    url: "https://dev.to/",
    category: tr ? "Topluluk" : "Community",
  },
  { title: "CSS-Tricks", url: "https://css-tricks.com/", category: "CSS" },
  {
    title: "Smashing Magazine",
    url: "https://www.smashingmagazine.com/",
    category: "Web Dev",
  },
  {
    title: "A List Apart",
    url: "https://alistapart.com/",
    category: "Web Dev",
  },
];

const setup = [
  { name: 'MacBook Pro 14"', category: tr ? "bilgisayar" : "computer" },
  { name: "VS Code", category: tr ? "editör" : "editor" },
  { name: "Arc Browser", category: tr ? "tarayıcı" : "browser" },
  { name: "Warp Terminal", category: "terminal" },
  { name: "Figma", category: tr ? "tasarım" : "design" },
  { name: "Notion", category: tr ? "notlar" : "notes" },
];

const playlists = [
  { id: "768iqNmf4DJINbq8nIhe2e", name: "Playlist 1" },
  { id: "7nTk4NzsYRlcB4yAuSPCuy", name: "Playlist 2" },
];
---

<div class="misc-page">
  <header class="page-head">
    <h1>{copy.title}</h1>
    <p class="page-intro">{copy.intro}</p>
    <nav class="page-index" aria-label={copy.title}>
      {
        sectionIndex.map((section, i) => (
          <>
            {i > 0 && <span class="index-sep" aria-hidden="true">·</span>}
            <a href={`#${section.id}`}>{section.label}</a>
          </>
        ))
      }
    </nav>
  </header>

  <section class="misc-section" id="listening">
    <div class="section-head">
      <h2>{copy.listening}</h2>
    </div>
    <p class="section-note">{copy.listeningDesc}</p>

    <div class="listening-grid">
      <div class="embed embed-wide">
        <iframe
          src="https://open.spotify.com/embed/track/0cZgkcbssrcJeetG4GXoLc?utm_source=generator&theme=0"
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title={copy.listening}></iframe>
      </div>
      {
        playlists.map((playlist) => (
          <div class="embed">
            <iframe
              src={`https://open.spotify.com/embed/playlist/${playlist.id}?utm_source=generator&theme=0`}
              width="100%"
              height="152"
              frameborder="0"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
              title={playlist.name}
            />
          </div>
        ))
      }
    </div>

    <a
      class="more-link"
      href={SITE_CONFIG.social.spotify}
      target="_blank"
      rel="noreferrer"
    >
      {copy.spotifyFollow}
    </a>
  </section>

  <section class="misc-section" id="bookmarks">
    <div class="section-head">
      <h2>{copy.bookmarks}</h2>
    </div>
    <p class="section-note">{copy.bookmarksDesc}</p>
    <ul class="leader-list">
      {
        bookmarks.map((item) => (
          <li>
            <a
              class="leader-row"
              href={item.url}
              target="_blank"
              rel="noreferrer"
            >
              <span class="row-title">{item.title}</span>
              <span class="row-leader" aria-hidden="true" />
              <span class="row-meta">{item.category}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <a class="more-link" href={`${basePath}/misc/bookmarks`}
      >{copy.allBookmarks}</a
    >
  </section>

  <section class="misc-section" id="books">
    <div class="section-head">
      <h2>{copy.books}</h2>
    </div>
    <p class="section-note">{copy.booksDesc}</p>
    <ul class="leader-list">
      {
        books.map((book) => (
          <li>
            <div class="leader-row">
              <span class="row-title">
                {book.title}<span class="row-author">, {book.author}</span>
              </span>
              <span class="row-leader" aria-hidden="true" />
              <span class="row-meta">{book.category}</span>
            </div>
          </li>
        ))
      }
    </ul>
    <a class="more-link" href={`${basePath}/misc/books`}>{copy.allBooks}</a>
  </section>

  <section class="misc-section" id="sources">
    <div class="section-head">
      <h2>{copy.sources}</h2>
    </div>
    <p class="section-note">{copy.sourcesDesc}</p>
    <ul class="leader-list">
      {
        sources.map((item) => (
          <li>
            <a
              class="leader-row"
              href={item.url}
              target="_blank"
              rel="noreferrer"
            >
              <span class="row-title">{item.title}</span>
              <span class="row-leader" aria-hidden="true" />
              <span class="row-meta">{item.category}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <a class="more-link" href={`${basePath}/misc/sources`}>{copy.allSources}</a>
  </section>

  <section class="misc-section" id="desk">
    <div class="section-head">
      <h2>{copy.desk}</h2>
    </div>
    <p class="section-note">{copy.deskDesc}</p>
    <p class="desk-line">
      {
        setup.map((item, i) => (
          <>
            {i > 0 && <span class="desk-sep" aria-hidden="true">·</span>}
            <span class="desk-item">
              {item.name}
              <span class="desk-cat"> ({item.category})</span>
            </span>
          </>
        ))
      }
    </p>
  </section>
</div>

<style>
  .misc-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 0 2rem;
    counter-reset: misc-section;
  }

  /* Page head */
  .page-head h1 {
    font-family: "Melodrama", serif;
    font-weight: 600;
    font-size: clamp(2.25rem, 6vw, 3.25rem);
    line-height: 1.1;
    margin: 0 0 0.75rem;
    color: var(--text-primary);
  }

  .page-intro {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
    max-width: 54ch;
  }

  .page-index {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 0.625rem;
    align-items: baseline;
  }

  .page-index a {
    font-size: 0.9375rem;
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s ease;
  }

  .page-index a:hover {
    text-decoration-color: var(--accent);
    color: var(--text-primary);
  }

  .index-sep {
    color: var(--text-muted);
    user-select: none;
  }

  /* Sections */
  .misc-section {
    margin-top: 3.5rem;
    scroll-margin-top: 6rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.625rem;
    margin-bottom: 0.75rem;
  }

  .section-head h2 {
    font-family: "Melodrama", serif;
    font-weight: 500;
    font-size: 1.5rem;
    margin: 0;
  }

  .section-head h2::before {
    counter-increment: misc-section;
    content: counter(misc-section, decimal-leading-zero);
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    margin-right: 0.75rem;
    vertical-align: 0.35em;
  }

  .section-note {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin: 0 0 1rem;
  }

  /* Leader lists */
  .leader-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .leader-list > li {
    border-bottom: 1px dashed
      color-mix(in srgb, var(--border) 70%, transparent);
  }

  .leader-list > li:last-child {
    border-bottom: none;
  }

  .leader-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .row-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  a.leader-row:hover .row-title {
    color: var(--accent);
  }

  .row-author {
    font-weight: 400;
    color: var(--text-secondary);
  }

  .row-leader {
    flex: 1;
    border-bottom: 1px dotted var(--border);
    transform: translateY(-4px);
    min-width: 2rem;
  }

  .row-meta {
    font-size: 0.8125rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .more-link {
    display: inline-block;
    margin-top: 0.875rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition:
      color 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .more-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* Listening */
  .listening-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .embed-wide {
    grid-column: 1 / -1;
  }

  .embed {
    border-radius: 12px;
    overflow: hidden;
  }

  .embed iframe {
    display: block;
    border-radius: 12px;
  }

  /* Desk */
  .desk-line {
    margin: 0;
    font-size: 1rem;
    line-height: 2;
    color: var(--text-primary);
  }

  .desk-item {
    white-space: nowrap;
  }

  .desk-cat {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .desk-sep {
    color: var(--text-muted);
    margin: 0 0.5rem;
    user-select: none;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .misc-section {
      margin-top: 3rem;
    }

    .listening-grid {
      grid-template-columns: 1fr;
    }

    .row-leader {
      display: none;
    }

    .row-title {
      flex: 1;
      min-width: 0;
    }
  }
</style>
