---
import { getLangFromUrl } from '../i18n/translations';

interface Props {
	date: Date;
}

const { date } = Astro.props;
const locale = getLangFromUrl(Astro.url) === 'tr' ? 'tr-TR' : 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
