---
import Layout from "../../layouts/Layout.astro";
import MiscArchive from "../../components/MiscArchive.astro";
import { type Lang } from "../../i18n/translations";
import { bookmarks } from "../../data/misc";

const lang: Lang = "en";
---

<Layout
  title="Bookmarks"
  description="Links I keep coming back to."
  lang={lang}
>
  <MiscArchive
    lang={lang}
    title="Bookmarks"
    intro="Links I keep coming back to."
    items={bookmarks}
  />
</Layout>
