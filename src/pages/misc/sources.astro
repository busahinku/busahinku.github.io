---
import Layout from "../../layouts/Layout.astro";
import MiscArchive from "../../components/MiscArchive.astro";
import { type Lang } from "../../i18n/translations";
import { sources } from "../../data/misc";

const lang: Lang = "en";
---

<Layout
  title="Sources"
  description="Where the daily dose of news and ideas comes from."
  lang={lang}
>
  <MiscArchive
    lang={lang}
    title="Sources"
    intro="Where the daily dose of news and ideas comes from."
    items={sources}
  />
</Layout>
