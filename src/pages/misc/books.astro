---
import Layout from "../../layouts/Layout.astro";
import MiscArchive from "../../components/MiscArchive.astro";
import { type Lang } from "../../i18n/translations";
import { books } from "../../data/misc";

const lang: Lang = "en";
---

<Layout
  title="Books"
  description="Books that changed how I think or work."
  lang={lang}
>
  <MiscArchive
    lang={lang}
    title="Books"
    intro="Books that changed how I think or work."
    items={books}
  />
</Layout>
