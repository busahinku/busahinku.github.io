---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ArchiveList from "../../components/ArchiveList.astro";
import { useTranslations, type Lang } from "../../i18n/translations";
import { calculateReadingTime } from "../../utils/readingTime";

const lang: Lang = "en";
const t = useTranslations(lang);

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const items = posts.map((post) => ({
  href: `/blog/${post.id}/`,
  title: post.data.title,
  date: post.data.pubDate,
  description: post.data.description,
  meta: `${t(`blog.category.${post.data.category}` as any)} · ${calculateReadingTime(post.body || "")} ${t("blog.minRead")}`,
}));
---

<Layout title={t("blog.title")} description={t("blog.description")} lang={lang}>
  <ArchiveList
    title={t("blog.title")}
    intro="Notes and essays, newest first."
    emptyNote="Nothing published yet. The first proper post is still in the drafts folder."
    items={items}
  />
</Layout>
