---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPostEnhanced from "../../../layouts/BlogPostEnhanced.astro";
import { useTranslations, type Lang } from "../../../i18n/translations";
import type { PostNavLink } from "../../../components/blog/PostNav.astro";

export async function getStaticPaths() {
  const courses = (
    await getCollection("courses", ({ data }) => !data.draft)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return courses.map((course, i) => ({
    params: { slug: course.id },
    props: {
      course,
      prevPost: courses[i + 1]
        ? {
            title: courses[i + 1].data.title,
            href: `/tr/courses/${courses[i + 1].id}/`,
          }
        : undefined,
      nextPost: courses[i - 1]
        ? {
            title: courses[i - 1].data.title,
            href: `/tr/courses/${courses[i - 1].id}/`,
          }
        : undefined,
    },
  }));
}

interface Props {
  course: CollectionEntry<"courses">;
  prevPost?: PostNavLink;
  nextPost?: PostNavLink;
}

const lang: Lang = "tr";
const t = useTranslations(lang);
const { course, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(course);
---

<BlogPostEnhanced
  post={course.data}
  headings={headings}
  lang={lang}
  slug={course.id}
  backUrl="/tr/courses"
  backLabel={t("nav.courses")}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</BlogPostEnhanced>
