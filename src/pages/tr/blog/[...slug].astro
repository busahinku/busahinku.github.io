---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPostEnhanced from "../../../layouts/BlogPostEnhanced.astro";
import type { Lang } from "../../../i18n/translations";
import type { PostNavLink } from "../../../components/blog/PostNav.astro";

// MDX Components
import ConceptCheck from "../../../components/blog/ConceptCheck.astro";
import VideoEmbed from "../../../components/blog/VideoEmbed.astro";
import PhotoGallery from "../../../components/blog/PhotoGallery.astro";
import Callout from "../../../components/blog/Callout.astro";
import Cite from "../../../components/blog/Cite.astro";
import Reference from "../../../components/blog/Reference.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = (
    await getCollection("blog", ({ data }) => !data.draft)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: posts[i + 1]
        ? {
            title: posts[i + 1].data.title,
            href: `/tr/blog/${posts[i + 1].id}/`,
          }
        : undefined,
      nextPost: posts[i - 1]
        ? {
            title: posts[i - 1].data.title,
            href: `/tr/blog/${posts[i - 1].id}/`,
          }
        : undefined,
    },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  prevPost?: PostNavLink;
  nextPost?: PostNavLink;
}

const lang: Lang = "tr";
const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

// MDX components to pass
const components = {
  ConceptCheck,
  VideoEmbed,
  PhotoGallery,
  Callout,
  Cite,
  Reference,
  Image,
};
---

<BlogPostEnhanced
  post={post.data}
  headings={headings}
  lang={lang}
  slug={post.id}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content components={components} />
</BlogPostEnhanced>
