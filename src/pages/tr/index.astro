---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { type Lang } from "../../i18n/translations";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_CONFIG } from "../../consts";
import FormattedDate from "../../components/FormattedDate.astro";

const lang: Lang = "tr";

const latestPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const latestProjects = (
  await getCollection("projects", ({ data }) => !data.draft)
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const links = [
  { label: "GitHub", href: SITE_CONFIG.social.github },
  { label: "LinkedIn", href: SITE_CONFIG.social.linkedin },
  { label: "X", href: SITE_CONFIG.social.twitter },
  { label: "Spotify", href: SITE_CONFIG.social.spotify },
  { label: "E-posta", href: `mailto:${SITE_CONFIG.email}` },
];
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} lang={lang}>
  <div class="home-page">
    <section class="intro">
      <h1 class="name">Burak Şahin Küçük</h1>
      <p class="intro-p">
        İnternetteki köşeme hoş geldin. Burada ders notlarımı, istatistik
        raporlarımı ve merak ettiğim ne varsa onu tutuyorum. ODTÜ'de
        istatistik ve bilgisayar mühendisliği okuyorum.
      </p>
      <p class="links">
        {
          links.map((link, i) => (
            <>
              {i > 0 && <span class="sep" aria-hidden="true">·</span>}
              <a
                href={link.href}
                target={link.href.startsWith("mailto") ? undefined : "_blank"}
                rel="noreferrer"
              >
                {link.label}
              </a>
            </>
          ))
        }
      </p>
    </section>

    {
      latestProjects.length > 0 && (
        <section class="index-section">
          <div class="section-head">
            <h2>İşler</h2>
            <a class="all-link" href="/tr/projects">
              tümü
            </a>
          </div>
          <ol class="toc-list">
            {latestProjects.map((project) => (
              <li>
                <a class="toc-row" href={`/tr/projects/${project.id}/`}>
                  <span class="toc-title">{project.data.title}</span>
                  <span class="toc-leader" aria-hidden="true" />
                  <span class="toc-meta">
                    {project.data.pubDate.getFullYear()}
                  </span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )
    }

    <section class="index-section">
      <div class="section-head">
        <h2>Yazılar</h2>
        {latestPosts.length > 0 && (
          <a class="all-link" href="/tr/blog">tümü</a>
        )}
      </div>
      {
        latestPosts.length > 0 ? (
          <ol class="toc-list">
            {latestPosts.map((post) => (
              <li>
                <a class="toc-row" href={`/tr/blog/${post.id}/`}>
                  <span class="toc-title">{post.data.title}</span>
                  <span class="toc-leader" aria-hidden="true" />
                  <span class="toc-meta">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <p class="empty-note">Yakında.</p>
        )
      }
    </section>
  </div>
</Layout>

<style>
  .home-page {
    max-width: 600px;
    margin: 0 auto;
    /* top padding clears the fixed header */
    padding: 9rem 1.25rem 4rem;
  }

  /* Intro */
  .name {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-size: clamp(1.375rem, 3.5vw, 1.75rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    color: var(--text-primary);
  }

  .intro-p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
    max-width: 58ch;
  }

  .intro-p a {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .intro-p a:hover {
    text-decoration-color: var(--accent);
  }

  .intro-p .read-more {
    color: var(--text-muted);
    text-decoration: none;
  }

  .intro-p .read-more:hover {
    color: var(--accent);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 0.625rem;
    align-items: baseline;
    margin: 0.25rem 0 0;
    font-size: 0.9375rem;
  }

  .links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .links a:hover {
    color: var(--accent);
  }

  .sep {
    color: var(--border);
    user-select: none;
  }

  /* Sections */
  .index-section {
    margin-top: 5rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .section-head h2 {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-size: 1.25rem;
    margin: 0;
  }

  .all-link {
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .all-link:hover {
    color: var(--accent);
  }

  /* Table-of-contents style lists */
  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: toc;
  }

  .toc-list > li {
    border-bottom: 1px dashed
      color-mix(in srgb, var(--border) 70%, transparent);
  }

  .toc-list > li:last-child {
    border-bottom: none;
  }

  .toc-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.875rem 0;
    text-decoration: none;
    color: inherit;
  }

  .toc-row::before {
    counter-increment: toc;
    content: counter(toc, decimal-leading-zero);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .toc-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .toc-row:hover .toc-title {
    color: var(--accent);
  }

  .toc-leader {
    flex: 1;
    border-bottom: 1px dotted var(--border);
    transform: translateY(-4px);
    min-width: 2rem;
  }

  .toc-meta {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .empty-note {
    font-size: 0.9375rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0.875rem 0 0;
  }

  @media (max-width: 640px) {
    .home-page {
      padding-top: 7rem;
    }

    .index-section {
      margin-top: 3.5rem;
    }

    .toc-leader {
      display: none;
    }

    .toc-title {
      flex: 1;
      min-width: 0;
    }
  }
</style>
