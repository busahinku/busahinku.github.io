---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPostEnhanced from "../../../layouts/BlogPostEnhanced.astro";
import { useTranslations, type Lang } from "../../../i18n/translations";
import type { PostNavLink } from "../../../components/blog/PostNav.astro";

export async function getStaticPaths() {
  const projects = (
    await getCollection("projects", ({ data }) => !data.draft)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return projects.map((project, i) => ({
    params: { slug: project.id },
    props: {
      project,
      prevPost: projects[i + 1]
        ? {
            title: projects[i + 1].data.title,
            href: `/tr/projects/${projects[i + 1].id}/`,
          }
        : undefined,
      nextPost: projects[i - 1]
        ? {
            title: projects[i - 1].data.title,
            href: `/tr/projects/${projects[i - 1].id}/`,
          }
        : undefined,
    },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
  prevPost?: PostNavLink;
  nextPost?: PostNavLink;
}

const lang: Lang = "tr";
const t = useTranslations(lang);
const { project, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(project);
---

<BlogPostEnhanced
  post={project.data}
  headings={headings}
  lang={lang}
  slug={project.id}
  github={project.data.github}
  demo={project.data.demo}
  backUrl="/tr/projects"
  backLabel={t("nav.projects")}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</BlogPostEnhanced>
