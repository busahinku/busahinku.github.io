---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ArchiveList from "../../../components/ArchiveList.astro";
import { useTranslations, type Lang } from "../../../i18n/translations";

const lang: Lang = "tr";
const t = useTranslations(lang);

const projects = (
  await getCollection("projects", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const items = projects.map((project) => ({
  href: `/tr/projects/${project.id}/`,
  title: project.data.title,
  date: project.data.pubDate,
  description: project.data.description,
  meta: [
    t(`projects.category.${project.data.category}` as any),
    project.data.tags.slice(0, 4).join(", "),
  ]
    .filter(Boolean)
    .join(" · "),
}));
---

<Layout
  title={t("projects.title")}
  description={t("projects.description")}
  lang={lang}
>
  <ArchiveList
    title={t("projects.title")}
    intro="Raporlar, uygulamalar ve çeşitli bitmişlik seviyelerinde deneyler."
    emptyNote="Henüz bir şey yok."
    items={items}
  />
</Layout>
