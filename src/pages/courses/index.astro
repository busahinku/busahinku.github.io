---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ArchiveList from "../../components/ArchiveList.astro";
import { useTranslations, type Lang } from "../../i18n/translations";
import { calculateReadingTime } from "../../utils/readingTime";

const lang: Lang = "en";
const t = useTranslations(lang);

const courses = (await getCollection("courses", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const items = courses.map((course) => ({
  href: `/courses/${course.id}/`,
  title: course.data.title,
  date: course.data.pubDate,
  description: course.data.description,
  meta: `${t(`courses.category.${course.data.category}` as any)} · ${calculateReadingTime(course.body || "")} ${t("blog.minRead")}`,
}));
---

<Layout
  title={t("courses.title")}
  description={t("courses.description")}
  lang={lang}
>
  <ArchiveList
    title={t("courses.title")}
    intro="Notes from the courses I take, written up properly."
    emptyNote="No course notes published yet. They are coming as I clean them up."
    items={items}
  />
</Layout>
